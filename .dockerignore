# .dockerignore

# OS-specific files
.DS_Store
Thumbs.db

# Node modules
node_modules
apps/*/node_modules
packages/*/node_modules

# Build outputs
.next
apps/*/.next
packages/*/dist
packages/*/build

# Turborepo cache
.turbo

# Git files
.git
.gitignore

# Env files (should not be included in the image)
.env*
! .env.example

# Docker files
Dockerfile
.dockerignore

# Local development logs/files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*