{
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "web:dev": "turbo run --filter=web dev",
    "native:dev": "turbo run --filter=native dev",
    "build": "turbo run build",
    "web:build": "turbo run --filter=web build",
    "native:build": "turbo run --filter=native build",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "type-check": "turbo run type-check",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "minimatch": "^10.1.1",
    "prettier": "^3.1.1",
    "turbo": "^2.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "with-react-native-web",
  "packageManager": "pnpm@10.20.0"
}
