{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ES2020",
    "declarationMap": true
  },
  "include": ["src/**/*", "src/**/*.tsx", "../../global.d.ts"],
  "exclude": ["node_modules", "dist"]
}

