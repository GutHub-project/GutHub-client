{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ES2020",
    "declarationMap": true,
    "paths": {
      "@repo/shared": ["../shared/src"],
      "@repo/shared/*": ["../shared/src/*"]
    },
    "baseUrl": ".",
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*", "../shared/src", "../../global.d.ts"],
  "exclude": ["node_modules", "dist"]
}

