{
  "name": "@repo/main-feature",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./pages": {
      "react-native": "./src/pages/index.ts",
      "types": "./dist/pages/index.d.ts",
      "import": "./dist/pages/index.mjs",
      "require": "./dist/pages/index.js"
    },
    "./apis/auth": {
      "react-native": "./src/apis/auth/index.ts",
      "types": "./dist/apis/auth.d.ts",
      "import": "./dist/apis/auth.mjs",
      "require": "./dist/apis/auth.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@tanstack/react-query": "^5.90.7",
    "react-native": "0.76.9",
    "axios": "^1.13.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.19.24",
    "@types/react": "^18.2.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "5.5.4"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0"
  }
}

