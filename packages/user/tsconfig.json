{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@repo/shared": ["../shared/src"],
      "@repo/shared/*": ["../shared/src/*"],
      "@repo/tailwind-config": ["../tailwind-config"],
      "@repo/tailwind-config/*": ["../tailwind-config/*"],
      "@repo/main-feature": ["../main-feature/src"],
      "@repo/main-feature/*": ["../main-feature/src/*"]
    },
    "types": ["node", "react", "react-native"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "../shared/src", "../tailwind-config", "../main-feature/src"],
  "exclude": ["node_modules", "dist"]
}
