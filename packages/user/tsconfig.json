{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@repo/*": ["../*"],
      "@repo/shared": ["../shared"],
      "@repo/tailwind-config": ["../tailwind-config"],
      "@repo/tailwind-config/*": ["../tailwind-config/*"]
    },
    "types": ["node", "react", "react-native"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
